# Copiar a .env y ajustar valores. No subir .env con datos reales al repositorio.

# Puertos
APP_PORT=9001
DB_PORT=3306

# Base de datos
DB_HOST=db
DB_USER=apsystem
DB_PASSWORD=apsystem
DB_NAME=apsystem
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_COLLATION=utf8mb4_general_ci
# Aplicación
APP_NAME="Control de Asistencia y Sistema de Nómina"
APP_TIMEZONE=America/Guayaquil
APP_DEBUG=0
COLLATION_CONNECTION=utf8mb4_general_ci